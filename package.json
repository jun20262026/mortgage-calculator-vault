{
  "name": "mortgage-calculator",
  "version": "1.0.0",
  "description": "房贷计算器 - Mortgage Calculator",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo android",
    "ios": "expo ios",
    "web": "expo web",
    "eject": "expo eject",
    "build:ios": "expo build:ios -t archive",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "expo": "~51.0.0",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "expo-crypto": "~13.0.0",
    "expo-file-system": "~17.0.0",
    "expo-media-library": "~16.0.0",
    "expo-document-picker": "~12.0.0",
    "expo-keep-awake": "~13.0.0",
    "expo-haptics": "~13.0.0",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-reanimated": "~3.10.1",
    "react-native-screens": "~3.31.1",
    "react-native-safe-area-context": "4.10.0",
    "react-native-webview": "13.8.6",
    "expo-secure-store": "~13.0.0",
    "crypto-js": "^4.2.0",
    "react-native-compressor": "^1.4.5",
    "expo-image-picker": "~15.0.0",
    "expo-video": "~1.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "babel-preset-expo": "^11.0.0",
    "patch-package": "^8.0.0"
  },
  "private": true,
  "expo": {
    "name": "房贷计算器",
    "slug": "mortgage-calculator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jun.mortgagecalc",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "需要访问相册以导入照片",
        "NSPhotoLibraryAddUsageDescription": "需要访问相册以保存照片",
        "NSDocumentsFolderUsageDescription": "需要访问文件以导入文件"
      }
    },
    "android": {
      "package": "com.jun.mortgagecalc",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    }
  }
}
